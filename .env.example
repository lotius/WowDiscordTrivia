PORT=3001

# Comma-separated. Any *.discordsays.com origin is allowed automatically.
CLIENT_ORIGIN=http://localhost:5173

# Leave EMPTY for Discord builds; the activity shares one origin via the proxy.
VITE_SERVER_URL=

VITE_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Required to use the question library, which exposes correct answers.
# Any long random string; paste it into the admin panel's token field.
ADMIN_TOKEN=

# --- Public HTTPS tunnel -----------------------------------------------------
# With none of these set you get a cloudflared quick tunnel, whose hostname
# changes on EVERY restart, so the Discord URL mapping needs re-pasting each
# time. Set one of the options below for a hostname that stays put.

# ngrok with a reserved static domain. Free tier includes one. Sign up, run
# "ngrok config add-authtoken <token>", reserve a domain in the dashboard, and
# put it here without the https:// prefix.
NGROK_DOMAIN=

# cloudflared named tunnel. Needs a domain in your Cloudflare account.
TUNNEL_NAME=
TUNNEL_HOSTNAME=
